FROM nginx:1.27-alpine AS runner

# NX builds static assets to dist/apps/<%= projectName %>/
# Run `nx build <%= projectName %>` before docker build
COPY dist/apps/<%= projectName %> /usr/share/nginx/html

COPY apps/<%= projectName %>/src/docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
